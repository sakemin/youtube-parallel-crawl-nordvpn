# youtube-parallel-crawl-nordvpn — configuration
# Copy to `config.env` and edit. Every value is overridable by an env var of the
# same name on the command line, e.g.  WORKERS=4 ./crawl.sh
# ---------------------------------------------------------------------------

# --- what to crawl ----------------------------------------------------------
IDS_FILE="./ids.txt"          # one YouTube video ID OR full URL per line
OUTPUT_DIR="./output"         # audio/<id[:2]>/<id>.<ext> + .meta, logs/, archive.shard<N>.txt
YTDLP_FORMAT="140/bestaudio[ext=m4a]/bestaudio"   # yt-dlp -f format selector
COOKIES_FILE=""               # optional cookies.txt (bypasses many age/bot gates)

# --- VPN / isolation --------------------------------------------------------
VPN_PROVIDER="nordvpn"
VPN_PROTOCOL="wireguard"      # wireguard (recommended: no auth throttle) | openvpn
VPN_DNS="1.1.1.1"             # in-namespace resolver. The provider's own DNS rate-limits
                              # under WORKERS parallel namespaces -> "Temporary failure in
                              # name resolution". Queried THROUGH the tunnel: no leak. ""=default.
# Workers lease IPs from a SHARED pool of all servers across these COUNTRIES, and
# the allocator keeps the live IPs in distinct countries (distinct /16s) -- workers
# stacked on one provider /24 trip YouTube's subnet-level bot detection. Use names
# as vopono lists them (vopono servers nordvpn). Give it >= WORKERS distinct
# countries so every live worker can sit in its own range.
COUNTRIES="south_korea japan singapore taiwan india thailand malaysia philippines"
WORKERS="8"                   # parallel workers; <= number of COUNTRIES and <= 9 (NordVPN 10-conn cap)

# --- throughput / rotation tuning ------------------------------------------
THREADS="2"                   # within-worker concurrency per IP (2 = YouTube-safe; >2 trips per-IP detector)
LIMIT="60"                    # successful downloads per IP before rotating to the next server
BLOCK_BUDGET="20"             # per-IP blocks tolerated before ending a batch; also the 403-count
                              # that marks an IP bot-flagged -> dormant
SETUP_WINDOW="8"              # seconds the setup-lock is held per worker (WireGuard ~5-8; OpenVPN ~20)
STAGGER="8"                   # seconds between initial worker launches
SETTLE="3"                    # base seconds between teardown and next spawn (jittered)
MAX_FAILS="8"                 # consecutive setup failures before a worker aborts
MIN_SUBSET="3"                # warn if a country has fewer than this many dialable servers
CAP="9"                       # NordVPN simultaneous-connection ceiling to honor
AUTH_COOLDOWN="150"           # OpenVPN only: global pause (s) when auth throttling is detected

# --- shared IP-pool allocation (lease + dormancy) --------------------------
COOLDOWN_MIN="30"             # minutes a bot-flagged IP stays dormant before it can be leased again
RECENT_SEC="180"             # seconds a just-released IP is held out (no back-to-back reuse)
LEASE_TTL="1800"             # seconds after which an abandoned lease (crashed worker) is reclaimed
BOT_FLAG_THRESHOLD="3"       # 'not a bot' hits within one batch that mark the IP flagged -> dormant

# --- paths (generated artifacts) -------------------------------------------
POOL_FILE="./servers.txt"     # generated server pool (build-pool / setup)
WG_DIR="/etc/wireguard/nordwg" # generated per-server WireGuard configs (root-owned)
VENV="./.venv"                # python venv with yt-dlp
